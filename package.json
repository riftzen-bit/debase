{
  "name": "debase",
  "version": "0.1.0",
  "private": true,
  "description": "Unified GUI shell for AI coding CLIs (Claude Code, Codex, OpenCode)",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "node scripts/launch.cjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/launch.cjs preview",
    "start": "node scripts/launch.cjs preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.137"
  },
  "devDependencies": {
    "@fontsource/geist-sans": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "codes.debase.app",
    "productName": "debase",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
