{
  "name": "debase",
  "version": "1.1.3",
  "private": true,
  "description": "Unified GUI shell for AI coding CLIs (Claude Code, Codex, OpenCode, Cursor)",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "node scripts/launch.cjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/launch.cjs preview",
    "start": "node scripts/launch.cjs preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "icon:build": "node scripts/build-icon.cjs",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.137",
    "@opencode-ai/sdk": "^1.3.15",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@fontsource/geist-sans": "^5.1.1",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.4.11",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.10.0",
    "png-to-ico": "^3.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "codes.debase.app",
    "productName": "debase",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out/**/*",
      "resources/icon.png",
      "resources/icon.ico",
      "resources/tray.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
